# ✅ โหมด Development สำหรับทำงานในเครื่องคอมพิวเตอร์
NODE_ENV=development
PORT=5000
# ⚠️ สำคัญมาก: เปลี่ยนค่านี้เป็น random string ที่ไม่ซ้ำกันใน production
# ใช้คำสั่ง: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_IN_PRODUCTION

# ==========================================
# 🗄️ DATABASE SETTINGS
# ==========================================
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=pawin_tech

# ==========================================
# 🌐 URL SETTINGS
# ==========================================
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000
REACT_APP_BASE_URL=http://localhost:5000

# ==========================================
# 📧 EMAIL & SERVICES
# ==========================================
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

REACT_APP_EMAILJS_SERVICE_ID=your_service_id
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id
REACT_APP_EMAILJS_USER_ID=your_user_id
